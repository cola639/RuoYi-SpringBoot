<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.qdpz.mapper.QdpzArticlesMapper">

    <resultMap type="QdpzArticles" id="QdpzArticlesResult">
        <result property="id" column="id"/>
        <result property="author" column="author"/>
        <result property="commentNums" column="comment_nums"/>
        <result property="content" column="content"/>
        <result property="createTime" column="create_time"/>
        <result property="cover" column="cover"/>
        <result property="imgList" column="img_list"/>
        <result property="likesNum" column="likes_num"/>
        <result property="seeNum" column="see_num"/>
        <result property="state" column="state"/>
        <result property="title" column="title"/>
        <result property="type" column="type"/>
    </resultMap>

    <sql id="selectQdpzArticlesVo">
        select id,
               author,
               comment_nums,
               content,
               create_time,
               cover,
               img_list,
               likes_num,
               see_num,
               state,
               title,
               type
        from qdpz_articles
    </sql>

    <select id="selectQdpzArticlesList" parameterType="QdpzArticles" resultMap="QdpzArticlesResult">
        <include refid="selectQdpzArticlesVo"/>
        <where>
            <if test="author != null  and author != ''">and author = #{author}</if>
            <if test="commentNums != null ">and comment_nums = #{commentNums}</if>
            <if test="content != null  and content != ''">and content = #{content}</if>
            <if test="cover != null  and cover != ''">and cover = #{cover}</if>
            <if test="imgList != null  and imgList != ''">and img_list = #{imgList}</if>
            <if test="likesNum != null ">and likes_num = #{likesNum}</if>
            <if test="seeNum != null ">and see_num = #{seeNum}</if>
            <if test="state != null ">and state = #{state}</if>
            <if test="title != null  and title != ''">and title = #{title}</if>
            <if test="type != null ">and type = #{type}</if>
        </where>
    </select>

    <select id="selectQdpzArticlesById" parameterType="Long" resultMap="QdpzArticlesResult">
        <include refid="selectQdpzArticlesVo"/>
        where id = #{id}
    </select>

    <insert id="insertQdpzArticles" parameterType="QdpzArticles" useGeneratedKeys="true" keyProperty="id">
        insert into qdpz_articles
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="author != null and author != ''">author,</if>
            <if test="commentNums != null">comment_nums,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="createTime != null">create_time,</if>
            <if test="cover != null and cover != ''">cover,</if>
            <if test="imgList != null and imgList != ''">img_list,</if>
            <if test="likesNum != null">likes_num,</if>
            <if test="seeNum != null">see_num,</if>
            <if test="state != null">state,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="type != null">type,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="author != null and author != ''">#{author},</if>
            <if test="commentNums != null">#{commentNums},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="cover != null and cover != ''">#{cover},</if>
            <if test="imgList != null and imgList != ''">#{imgList},</if>
            <if test="likesNum != null">#{likesNum},</if>
            <if test="seeNum != null">#{seeNum},</if>
            <if test="state != null">#{state},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="type != null">#{type},</if>
        </trim>
    </insert>

    <update id="updateQdpzArticles" parameterType="QdpzArticles">
        update qdpz_articles
        <trim prefix="SET" suffixOverrides=",">
            <if test="author != null and author != ''">author = #{author},</if>
            <if test="commentNums != null">comment_nums = #{commentNums},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="cover != null and cover != ''">cover = #{cover},</if>
            <if test="imgList != null and imgList != ''">img_list = #{imgList},</if>
            <if test="likesNum != null">likes_num = #{likesNum},</if>
            <if test="seeNum != null">see_num = #{seeNum},</if>
            <if test="state != null">state = #{state},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="type != null">type = #{type},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteQdpzArticlesById" parameterType="Long">
        delete
        from qdpz_articles
        where id = #{id}
    </delete>

    <delete id="deleteQdpzArticlesByIds" parameterType="String">
        delete from qdpz_articles where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>